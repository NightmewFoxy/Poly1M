# Polymarket CLOB API credentials (generate from Polymarket Settings -> API Keys)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Polygon wallet
POLYMARKET_WALLET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Signature type (must match how your Polymarket account is set up):
#   0 = EOA              (you ARE the funder, maker == signer)
#   1 = POLY_PROXY       (Magic.link / email signup — most legacy accounts)
#   2 = POLY_GNOSIS_SAFE (Polymarket browser-wallet account, Gnosis Safe)
#   3 = POLY_1271        (deposit wallet — some V2-only accounts)
POLYMARKET_SIGNATURE_TYPE=1

# IMPORTANT: POLYMARKET_FUNDER_ADDRESS is your *trading* wallet, NOT the
# "deposit address" shown in the Polymarket UI's Cash tab. The deposit address
# is where USDC arrives. The trading wallet is the POLY_PROXY contract
# derived from your relayer EOA — different address.
#
# To find your trading wallet: place one tiny trade in the Polymarket web UI,
# then run from this repo:
#   python -c "from polymarket_client import clob; import json; \
#     r=clob().get_trades(); print(json.dumps(r,indent=2,default=str))"
# and read `maker_address` from the most recent trade. That's your funder.

# Anthropic API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Kill switch: set to "false" to pause trading (cycles + research still run, cache stays warm)
TRADING_ENABLED=true

# Operational tuning (defaults are sane, leave blank to use them)
LOOP_INTERVAL_SECONDS=1800
MAX_OPEN_POSITIONS=10
STAKE_USD=10
MIN_VOLUME_USD=10000
MAX_PRICE=0.80
# Floor: skip any side priced below this. Cheap markets at ~$0.001 are usually
# already-resolved markets where Claude's true_prob_yes >= 0.02 clamp produces
# fake huge-EV trades on the dead side.
MIN_PRICE=0.05
# Sanity cap on Claude's EV estimate. Real soft-edge trades on esports markets
# sit in the single-digit to low-double-digit cents/dollar range. Higher than
# this is almost always a stale/resolved market fooling the EV math.
MAX_EV_CENTS_PER_DOLLAR=50
MIN_HOURS_TO_RESOLUTION=2
POLYMARKET_FEE=0.02

# Data dir (Railway volume mount; defaults to ./data locally)
DATA_DIR=./data

# -----------------------------------------------------------------------------
# Sniper bot (sniper_main.py) — separate process, BTC 5-min price-trigger.
# Lives alongside the esports bot; uses its own state file (sniper_positions.json),
# its own kill switch (SNIPER_ENABLED), and its own dry-run mode (SNIPER_DRY_RUN).
# Defaults: $5 stake, live mode (SNIPER_DRY_RUN unset → live).
# -----------------------------------------------------------------------------
SNIPER_ENABLED=true
# DRY_RUN=true logs WOULD-HAVE-FIRED messages and does NOT place orders.
# Default is live trading; set to "true" only when you want to dry-run.
SNIPER_DRY_RUN=false
SNIPER_STAKE_USD=5
# Strategy: buy the first side (UP or DOWN) of the active BTC 5m market
# whose ask reaches this price level. Polymarket-only trigger.
SNIPER_TRIGGER_PRICE=0.69
# Max slippage tolerated above target_price, in ticks. The CLOB will
# FOK-kill the order if the avg fill price would exceed
# target_price + N*tick_size. 10 ticks ($0.10 at 0.01 tick) is usually
# enough for a $5 stake; bump higher if you keep seeing
# "order couldn't be fully filled" errors, lower if you want to limit
# how far above your trigger you're willing to pay.
SNIPER_MAX_SLIPPAGE_TICKS=10
# Minimum gap between fires regardless of signal strength.
SNIPER_COOLDOWN_SECONDS=60
# Hard daily loss stop (UTC midnight rollover).
SNIPER_DAILY_LOSS_LIMIT_USD=20
# Legacy Binance-move knobs (the feed still runs as an informational BTC
# tape; these no longer drive trade decisions, but the parser still reads
# them so leave them set or remove entirely).
SNIPER_MOVE_THRESHOLD_PCT=0.3
SNIPER_LOOKBACK_SECONDS=20
SNIPER_MIN_EDGE_CENTS=3
# Binance symbol stream (e.g. btcusdt, ethusdt). Lowercase.
SNIPER_BINANCE_SYMBOL=btcusdt
