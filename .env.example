# Polymarket CLOB API credentials (generate from Polymarket Settings -> API Keys)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Polygon wallet
POLYMARKET_WALLET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Signature type (must match how you signed up):
#   0 = EOA (you ARE the funder, maker == signer)
#   1 = POLY_PROXY (legacy Magic.link / email signup, pre-2024)
#   2 = POLY_GNOSIS_SAFE (Polymarket browser-wallet account, Gnosis Safe)
#   3 = POLY_1271 (deposit wallet - default for new accounts post Apr 28, 2026)
# After Polymarket's V2 upgrade you must also sign the USDC->pUSD conversion
# prompt in the web UI once, otherwise CLOB rejects orders with "use the deposit
# wallet flow" even with the right sigtype set.
POLYMARKET_SIGNATURE_TYPE=3

# Anthropic API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Kill switch: set to "false" to pause trading (cycles + research still run, cache stays warm)
TRADING_ENABLED=true

# Operational tuning (defaults are sane, leave blank to use them)
LOOP_INTERVAL_SECONDS=1800
MAX_OPEN_POSITIONS=10
STAKE_USD=10
MIN_VOLUME_USD=10000
MAX_PRICE=0.80
MIN_HOURS_TO_RESOLUTION=2
POLYMARKET_FEE=0.02

# Data dir (Railway volume mount; defaults to ./data locally)
DATA_DIR=./data
