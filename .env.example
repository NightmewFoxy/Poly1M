# Polymarket CLOB API credentials (generate from Polymarket Settings -> API Keys)
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# Polygon wallet
POLYMARKET_WALLET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=

# Signature type (must match how your Polymarket account is set up):
#   0 = EOA              (you ARE the funder, maker == signer)
#   1 = POLY_PROXY       (Magic.link / email signup — most legacy accounts)
#   2 = POLY_GNOSIS_SAFE (Polymarket browser-wallet account, Gnosis Safe)
#   3 = POLY_1271        (deposit wallet — some V2-only accounts)
POLYMARKET_SIGNATURE_TYPE=1

# IMPORTANT: POLYMARKET_FUNDER_ADDRESS is your *trading* wallet, NOT the
# "deposit address" shown in the Polymarket UI's Cash tab. The deposit address
# is where USDC arrives. The trading wallet is the POLY_PROXY contract
# derived from your relayer EOA — different address.
#
# To find your trading wallet: place one tiny trade in the Polymarket web UI,
# then run from this repo:
#   python -c "from polymarket_client import clob; import json; \
#     r=clob().get_trades(); print(json.dumps(r,indent=2,default=str))"
# and read `maker_address` from the most recent trade. That's your funder.

# Anthropic API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Kill switch: set to "false" to pause trading (cycles + research still run, cache stays warm)
TRADING_ENABLED=true

# Operational tuning (defaults are sane, leave blank to use them)
LOOP_INTERVAL_SECONDS=1800
MAX_OPEN_POSITIONS=10
STAKE_USD=10
MIN_VOLUME_USD=10000
MAX_PRICE=0.80
MIN_HOURS_TO_RESOLUTION=2
POLYMARKET_FEE=0.02

# Data dir (Railway volume mount; defaults to ./data locally)
DATA_DIR=./data
